# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# test coverage reports
coverage/

# generated native folders
/ios
/android

# Development rules (not for git)
.cursorrules

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# ============================================================================
# MARKDOWN FILE RULES (See WORKFLOW.md > CORE PRINCIPLE)
# ============================================================================
# ALLOWED IN REPO: Configuration, project state, onboarding (.instructions.md, WORKFLOW.md, PROJECT_MEMORY/*, etc.)
# NEVER COMMIT: Ephemeral work (reviews, checkpoints, plans, session notes)
# Reason: Once decisions are made, code is truth. Ephemeral files clutter history.
# Exceptions handled by .gitignore patterns below:
# ============================================================================

# Ephemeral docs - never commit (see WORKFLOW.md > CORE PRINCIPLE)
# Review documents
*_REVIEW*.md
*_CODE_REVIEW*.md

# Checkpoint & session files
*_CHECKPOINT*.md
*_SESSION*.md
SESSION_*.md

# Planning documents
*_PLAN*.md
*_ROADMAP*.md
*_PROPOSAL*.md

# Test reports and output
TEST_RESULTS*.md
TEST_OUTPUT*.md

# Other discussions and personal documents
other discussions/

